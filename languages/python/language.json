{
  "id": "python",
  "name": {
    "fr": "Python",
    "en": "Python"
  },
  "docker_image": "maat-python-runner:latest",
  "allowed_extensions": [
    ".py",
    ".json",
    ".txt",
    ".csv"
  ],
  "entrypoints": [
    "main.py",
    "src/main.py"
  ],
  "allow_custom_build_file": false,
  "build_command": "python3 -m py_compile $(find . -name '*.py' -type f | sort)",
  "run_command": "python3 main.py {instance_file}",
  "compile_timeout_seconds": 20,
  "run_timeout_seconds": 120,
  "compile_resources": {
    "cpus": "4",
    "memory": "512m",
    "pids_limit": 128
  },
  "run_resources": {
    "cpus": "2",
    "memory": "512m",
    "pids_limit": 128
  },
  "forbidden_patterns": [
    "os.system",
    "subprocess",
    "socket",
    "requests",
    "urllib",
    "http.client",
    "ftplib",
    "paramiko",
    "shutil.rmtree",
    "pathlib.Path.unlink",
    "eval",
    "exec",
    "compile",
    "__import__"
  ]
}